# Cloud IDE Platform - Local Development Environment
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cloud_ide

# Redis
REDIS_URL=redis://localhost:6379/0

# Security - CHANGE THIS IN PRODUCTION
SECRET_KEY=dev-secret-key-change-in-production-min-32-chars-long-dev-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60


# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_PUBLIC_ENDPOINT=focuses-crossword-perl-teaches.trycloudflare.com
MINIO_PUBLIC_SECURE=true
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=workspace-data

# Workspace Configuration
MAX_WORKSPACES_PER_USER=2
IDLE_TIMEOUT_SECONDS=1800

# API Docs
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
PUBLIC_API_BASE_URL=https://chocolate-submit-scanned-diverse.trycloudflare.com
COLAB_TEMPLATE_REF=7f9422bc397d1c74abef4996cc8655f7f4037afe

# DVC – path to a local git+dvc repo used for tracking dataset versions
# Run: git init /srv/dvc-repo && dvc init && dvc remote add -d minio s3://...
DVC_REPO_PATH=D:\Documents\Lap_trinh\NeuralSpace\dvc-repo
DVC_REMOTE_NAME=minio
DVC_MANAGED_REPO_ROOT=D:\Documents\Lap_trinh\NeuralSpace\dvc-repos

#docker compose up -d --force-recreate api

