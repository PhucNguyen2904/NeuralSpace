# Cloud IDE Platform - Local Development Environment
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cloud_ide

# Redis
REDIS_URL=redis://localhost:6379/0

# Security - CHANGE THIS IN PRODUCTION
SECRET_KEY=dev-secret-key-change-in-production-min-32-chars-long-dev-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Kubernetes
KUBERNETES_IN_CLUSTER=false
KUBERNETES_NAMESPACE_PREFIX=ws-

# Jupyter
JUPYTER_BASE_IMAGE=registry.platform.com/jupyter-base:latest

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_PUBLIC_ENDPOINT=bathroom-oldest-talks-both.trycloudflare.com
MINIO_PUBLIC_SECURE=true
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=workspace-data

# Workspace Configuration
MAX_WORKSPACES_PER_USER=2
IDLE_TIMEOUT_SECONDS=1800

# API Docs
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
PUBLIC_API_BASE_URL=https://bathroom-oldest-talks-both.trycloudflare.com/api/v1
COLAB_TEMPLATE_REF=e7ada2ba408694a5befcb4c646958b4786a05598
