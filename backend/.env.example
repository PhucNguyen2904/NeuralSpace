# === DATABASE ===
DATABASE_URL=postgresql+asyncpg://ml_app_user:ChangeThisInProd_App_123!@postgres:5432/ml_model_store
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# === REDIS ===
REDIS_URL=redis://redis:6379/0

# === CELERY ===
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_WORKER_CONCURRENCY=2
CELERY_MAX_MEMORY_PER_CHILD=2097152

# === STORAGE ===
STORAGE_BASE_PATH=/data/models
TEMP_DOWNLOAD_PATH=/tmp/model_downloads
MIN_FREE_DISK_GB=5.0

# === DOWNLOAD ===
CHUNK_SIZE_BYTES=8388608
MAX_RETRY_COUNT=3
CONNECT_TIMEOUT=30
READ_TIMEOUT=60
DISK_CHECK_INTERVAL_BYTES=52428800
MAX_CONCURRENT_DOWNLOADS=3

# === HUGGINGFACE ===
HF_DEFAULT_TOKEN=

# === API ===
API_V1_PREFIX=/api/v1
LOG_LEVEL=info
DEBUG=false

# === POSTGRES (docker-compose) ===
POSTGRES_USER=ml_app_user
POSTGRES_PASSWORD=ChangeThisInProd_App_123!
POSTGRES_DB=ml_model_store
