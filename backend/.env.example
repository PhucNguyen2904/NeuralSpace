# NeuralSpace Control Plane - Development Environment
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/cloud_ide

# Redis
REDIS_URL=redis://redis:6379/0

# Security - CHANGE THIS IN PRODUCTION
SECRET_KEY=dev-secret-key-change-in-production-min-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# MinIO
MINIO_ENDPOINT=minio:9000
# Must be reachable from Google Colab, for example your tunnel host without scheme.
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_PUBLIC_SECURE=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=workspace-data

# API Docs
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Colab Integration
PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
COLAB_TEMPLATE_ORGANIZATION=neuralspace-ai
COLAB_TEMPLATE_REPOSITORY=colab-templates
COLAB_TEMPLATE_REF=7f9422bc397d1c74abef4996cc8655f7f4037afe
COLAB_TEMPLATE_NOTEBOOK_PATH=notebooks/bootstrap.ipynb
COLAB_CLAIM_EXPIRE_SECONDS=120
COLAB_RUNTIME_TOKEN_EXPIRE_MINUTES=480
COLAB_DATA_URL_EXPIRE_SECONDS=900

# DVC
# Used by "Server default" when users do not configure their own DVC profile.
DVC_REPO_PATH=/srv/dvc-repo
DVC_REMOTE_NAME=minio
DVC_MANAGED_REPO_ROOT=/srv/dvc-repos
