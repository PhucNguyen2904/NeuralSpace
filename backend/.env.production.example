# NeuralSpace Backend — Production Environment (Render)
# Sao chép file này thành .env trên Render (hoặc dùng Render Environment Variables UI)
# KHÔNG commit file này nếu đã điền giá trị thật.

ENVIRONMENT=production
LOG_LEVEL=INFO

# ─── Database (Neon PostgreSQL) ─────────────────────────────────────────────
# Lấy từ: Neon Dashboard → Connection Details → Connection string
# Đảm bảo dùng asyncpg driver và thêm ?sslmode=require
DATABASE_URL=postgresql://<user>:<password>@<host>/<dbname>?sslmode=require

# Pool size nhỏ cho Neon serverless (free tier giới hạn concurrent connections)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=0

# ─── Redis (Upstash) ─────────────────────────────────────────────────────────
# Lấy từ: Upstash Console → Database → REST API → rediss:// URL
# Lưu ý: scheme phải là rediss:// (có SSL)
REDIS_URL=rediss://default:<password>@<host>:<port>

# ─── Security ────────────────────────────────────────────────────────────────
# Tạo SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<your-secret-key>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Tạo SSH_KEY_ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SSH_KEY_ENCRYPTION_KEY=<your-ssh-encryption-key>

# Tạo OAUTH_ENCRYPTION_KEY tương tự SSH_KEY_ENCRYPTION_KEY
OAUTH_ENCRYPTION_KEY=<your-oauth-encryption-key>

# ─── Cloudflare R2 (Object Storage) ─────────────────────────────────────────
# Lấy từ: Cloudflare Dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=<cloudflare-account-id>
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET_NAME=neuralspace-data
# Nếu bật public access trên R2 bucket:
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# ─── URLs & CORS ─────────────────────────────────────────────────────────────
# Thêm domain Vercel frontend vào CORS
CORS_ORIGINS=https://<your-app>.vercel.app,https://<custom-domain.com>

# URL công khai của backend (dùng cho Colab integration)
PUBLIC_API_BASE_URL=https://<your-backend>.onrender.com/api/v1
FRONTEND_URL=https://<your-app>.vercel.app

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# Tạo GitHub OAuth App mới cho production tại: github.com/settings/developers
GITHUB_CLIENT_ID=<github-client-id>
GITHUB_CLIENT_SECRET=<github-client-secret>
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/git/accounts/oauth/callback

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials
# Callback URL: https://<backend>.onrender.com/api/v1/storage/oauth/callback
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>

# ─── Microsoft OneDrive OAuth ─────────────────────────────────────────────────
# Azure Portal → App registrations → New registration
# Redirect URI: https://<backend>.onrender.com/api/v1/storage/oauth/callback
ONEDRIVE_CLIENT_ID=<azure-app-client-id>
ONEDRIVE_CLIENT_SECRET=<azure-app-client-secret>

# ─── Dropbox OAuth ────────────────────────────────────────────────────────────
# Dropbox App Console: www.dropbox.com/developers/apps
# Redirect URI: https://<backend>.onrender.com/api/v1/storage/oauth/callback
DROPBOX_APP_KEY=<dropbox-app-key>
DROPBOX_APP_SECRET=<dropbox-app-secret>

# ─── Storage Configs (rclone.conf per user) ──────────────────────────────────
# Persistent volume path chứa rclone.conf của mỗi user
# Trên Render: mount persistent disk tại /storage-configs
STORAGE_CONFIGS_DIR=/storage-configs

# ─── Colab Integration ────────────────────────────────────────────────────────
# PHẢI là commit SHA 40 ký tự hoặc release tag trong production
COLAB_TEMPLATE_REF=7f9422bc397d1c74abef4996cc8655f7f4037afe

# ─── DVC (ephemeral — tự clone lại sau restart) ──────────────────────────────
# Render free tier không có persistent disk — dùng /tmp
DVC_REPO_PATH=/tmp/dvc-repo
DVC_REMOTE_NAME=r2
DVC_MANAGED_REPO_ROOT=/tmp/dvc-repos
