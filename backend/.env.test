# Cloud IDE Platform - Test Environment
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Database - In-memory SQLite for tests
DATABASE_URL=sqlite+aiosqlite:///:memory:

# Redis
REDIS_URL=redis://localhost:6379/1

# Security
SECRET_KEY=test-secret-key-min-32-chars-long-test-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Kubernetes
KUBERNETES_IN_CLUSTER=false
KUBERNETES_NAMESPACE_PREFIX=ws-

# Jupyter
JUPYTER_BASE_IMAGE=registry.platform.com/jupyter-base:latest

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=workspace-data

# Workspace Configuration
MAX_WORKSPACES_PER_USER=2
IDLE_TIMEOUT_SECONDS=1800

# API Docs
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
