# NeuralSpace Frontend — Production Environment (Vercel)
# Điền các giá trị này vào Vercel Dashboard → Project → Settings → Environment Variables
# KHÔNG commit file này nếu đã điền giá trị thật.

# URL backend Render — PHẢI có /api/v1 ở cuối
NEXT_PUBLIC_API_URL=https://<your-backend>.onrender.com/api/v1

# Jupyter không có trong production — xóa hoặc để trống các biến này
# NEXT_PUBLIC_JUPYTER_TOKEN=
# NEXT_PUBLIC_JUPYTER_REST_URL=
# NEXT_PUBLIC_JUPYTER_WS_URL=
